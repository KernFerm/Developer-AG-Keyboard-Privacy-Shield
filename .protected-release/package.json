{
  "name": "developer-anti-ghosting-keyboard-privacy-shield",
  "version": "0.2.7",
  "description": "Privacy-first local-only Electron dashboard for keystroke visibility awareness, trusted devices, workspace protection, and accessibility.",
  "main": "src/main.js",
  "author": "bubblesthedev",
  "license": "GPL-3.0-only",
  "scripts": {
    "build": "electron-builder --dir",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac zip",
    "build:linux": "electron-builder --linux AppImage"
  },
  "build": {
    "appId": "local.dev.antighosting.privacyshield",
    "compression": "maximum",
    "productName": "Developer Anti Ghosting Keyboard Privacy Shield",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "docs/**/*",
      "extensions/**/*",
      "src/**/*",
      "scripts/**/*",
      "tests/**/*",
      "package.json",
      "CHANGE-LOG.md",
      "README.md",
      "LICENSE"
    ],
    "win": {
      "forceCodeSigning": false,
      "signAndEditExecutable": false,
      "icon": "icon.png",
      "target": [
        "portable",
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "license": "build/LICENSE.txt",
      "include": "build/installer.nsh",
      "createDesktopShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}",
      "requestExecutionLevel": "user"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg"
      ],
      "artifactName": "${productName}-${version}-mac.${ext}"
    },
    "linux": {
      "category": "Utility",
      "target": [
        "AppImage"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "javascript-obfuscator": "^5.4.3"
  }
}